# AI News Radar — environment configuration template.
# Copy to `.env` and adjust. `.env` is git-ignored.
#
# Only variables marked [WIRED] are read by the current code. The others are
# documented placeholders for sources that are not yet connected, so the config
# stays honest about what is actually live.

# [WIRED] User-Agent sent on every outbound request. SEC EDGAR expects a
# descriptive agent with a contact address; set a real contact before heavy use.
AI_NEWS_RADAR_USER_AGENT=ai-news-radar/0.2 research-tool contact=you@example.com

# [WIRED] Log verbosity for the CLI and web server: DEBUG / INFO / WARNING / ERROR.
AI_NEWS_RADAR_LOG_LEVEL=INFO

# [NOT WIRED YET] EIA petroleum/energy API key. The EIA market source is marked
# `requires_key` and is skipped until key-based fetching is implemented.
# EIA_API_KEY=

# [NOT WIRED YET] Credentials for unusual-options-flow ingestion (X / Jina /
# vendor API). The Flow God source stays in `requires_x_or_jina_api` state and
# is never treated as confirmed evidence until a real feed is connected.
# OPTIONS_FLOW_API_KEY=
